---
import { useTranslations, getLocalizedPath, getAlternateLang, type Lang } from "~/i18n/utils";
import { languages } from "~/i18n/ui";
import PillNav from "../islands/PillNav.tsx";
import "../islands/PillNav.css";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const home = getLocalizedPath(lang, "/");

const items = [
  { href: home, label: t("nav.home") },
  { href: getLocalizedPath(lang, lang === "es" ? "/proyectos" : "/projects"), label: t("nav.projects") },
  { href: getLocalizedPath(lang, lang === "es" ? "/servicios" : "/services"), label: t("nav.services") },
  { href: getLocalizedPath(lang, lang === "es" ? "/contacto" : "/contact"), label: t("nav.contact") },
];

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const activeItem = items.find((i) => (i.href.replace(/\/$/, "") || "/") === currentPath);
const activeHref = activeItem?.href ?? home;

const other = getAlternateLang(lang);
const pathWithoutLang =
  lang === "es" ? Astro.url.pathname : Astro.url.pathname.replace(/^\/en(\/|$)/, "/");
const targetHref = getLocalizedPath(other, pathWithoutLang);
---

<a
  href="#main"
  class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:bg-accent-500 focus:text-ink-950 focus:px-4 focus:py-2 focus:rounded-sm"
>
  Skip to content
</a>

<div class="floating-nav">
  <PillNav
    logo="/logo-ac.svg"
    logoAlt="Antonio Cortazar"
    items={items}
    activeHref={activeHref}
    baseColor="var(--pill-base)"
    pillColor="var(--pill-bg-color)"
    pillTextColor="var(--pill-text-color)"
    hoveredPillTextColor="var(--pill-hover-text)"
    languageToggle={{
      currentCode: languages[lang],
      targetHref,
      ariaLabel: `Switch language to ${languages[other]}`,
    }}
    themeToggle
    client:load
  />
</div>

<style is:global>
  :root {
    --pill-base: #0a0a0b;
    --pill-bg-color: #f4f2ed;
    --pill-text-color: #0a0a0b;
    --pill-hover-text: #f4f2ed;
  }

  :root.theme-dark {
    --pill-base: #f4f2ed;
    --pill-bg-color: #0a0a0b;
    --pill-text-color: #f4f2ed;
    --pill-hover-text: #0a0a0b;
  }

  .floating-nav {
    position: fixed;
    top: 1rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 50;
    pointer-events: none;
    max-width: calc(100vw - 2rem);
    transition: transform 0.35s ease;
    will-change: transform;
  }

  .floating-nav.is-hidden {
    transform: translateX(-50%) translateY(calc(-100% - 1.5rem));
  }

  .floating-nav > * {
    pointer-events: auto;
  }

  @media (max-width: 768px) {
    .floating-nav {
      left: 1rem;
      right: 1rem;
      transform: none;
      max-width: none;
    }

    .floating-nav.is-hidden {
      transform: translateY(calc(-100% - 1.5rem));
    }
  }
</style>
