---
type Variant = "primary" | "secondary" | "ghost";
type Size = "sm" | "md" | "lg";

interface Props {
  href?: string | URL;
  variant?: Variant;
  size?: Size;
  type?: "button" | "submit" | "reset";
  external?: boolean;
  class?: string;
  ariaLabel?: string;
}

const {
  href,
  variant = "primary",
  size = "md",
  type = "button",
  external = false,
  class: className = "",
  ariaLabel,
} = Astro.props;

const base =
  "inline-flex items-center justify-center gap-2 rounded-sm font-medium font-sans transition-all duration-200 ease-out focus-visible:outline-2 focus-visible:outline-accent-500 focus-visible:outline-offset-2 select-none";

const variants: Record<Variant, string> = {
  primary:
    "bg-accent-500 text-ink-950 hover:bg-accent-600 active:scale-[0.98]",
  secondary:
    "border border-ink-300 text-ink-950 hover:bg-ink-100 hover:border-ink-950 dark:border-ink-700 dark:text-ink-100 dark:hover:bg-ink-800 dark:hover:border-ink-100",
  ghost:
    "text-ink-950 hover:text-accent-500 dark:text-ink-100 dark:hover:text-accent-400",
};

const sizes: Record<Size, string> = {
  sm: "px-3 py-2 text-sm",
  md: "px-5 py-3 text-base",
  lg: "px-7 py-4 text-lg",
};

const cls = `${base} ${variants[variant]} ${sizes[size]} ${className}`;
const rel = external ? "noopener noreferrer" : undefined;
const target = external ? "_blank" : undefined;
---

{
  href ? (
    <a href={href} class={cls} aria-label={ariaLabel} rel={rel} target={target}>
      <slot />
    </a>
  ) : (
    <button type={type} class={cls} aria-label={ariaLabel}>
      <slot />
    </button>
  )
}
