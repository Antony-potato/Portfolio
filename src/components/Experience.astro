---
interface Props {
  t: (key: string) => string;
}

const { t } = Astro.props;
---

<section id="experience" class="section-padding bg-bg-secondary/50">
  <div class="text-center mb-16">
    <span class="section-label">{t('experience.label')}</span>
    <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold">{t('experience.heading')}</h2>
  </div>

  <div class="max-w-3xl mx-auto space-y-8">
    <!-- Onix Living -->
    <div class="timeline-item">
      <div class="timeline-dot"></div>
      <div class="timeline-content">
        <div class="timeline-header">
          <div>
            <h3 class="timeline-role">{t('experience.onix.role')}</h3>
            <p class="timeline-company">{t('experience.onix.company')}</p>
          </div>
          <span class="timeline-period">{t('experience.onix.period')}</span>
        </div>
        <p class="timeline-desc">{t('experience.onix.desc')}</p>
        <div class="timeline-tags">
          <span class="tag">Astro</span>
          <span class="tag">Next.js</span>
          <span class="tag">Leaflet</span>
          <span class="tag">AWS</span>
          <span class="tag">Snipe-IT</span>
          <span class="tag">Google Sheets API</span>
        </div>
      </div>
    </div>

    <!-- Office Depot -->
    <div class="timeline-item">
      <div class="timeline-dot"></div>
      <div class="timeline-content">
        <div class="timeline-header">
          <div>
            <h3 class="timeline-role">{t('experience.officedepot.role')}</h3>
            <p class="timeline-company">{t('experience.officedepot.company')}</p>
          </div>
          <span class="timeline-period">{t('experience.officedepot.period')}</span>
        </div>
        <p class="timeline-desc">{t('experience.officedepot.desc')}</p>
        <div class="timeline-tags">
          <span class="tag">Leadership</span>
          <span class="tag">KPIs</span>
          <span class="tag">Technical Support</span>
          <span class="tag">Sales</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .section-label {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-accent);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .timeline-item {
    display: flex;
    gap: 1.5rem;
    position: relative;
  }

  .timeline-dot {
    width: 12px;
    height: 12px;
    min-width: 12px;
    background: var(--color-accent);
    border-radius: 50%;
    margin-top: 0.5rem;
    position: relative;
  }

  .timeline-dot::after {
    content: '';
    position: absolute;
    top: 16px;
    left: 50%;
    transform: translateX(-50%);
    width: 2px;
    height: calc(100% + 2rem);
    background: var(--color-border);
  }

  .timeline-item:last-child .timeline-dot::after {
    display: none;
  }

  .timeline-content {
    padding: 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    flex: 1;
    transition: all 0.3s ease;
  }

  .timeline-content:hover {
    border-color: var(--color-border-hover);
  }

  .timeline-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .timeline-role {
    font-size: 1.1rem;
    font-weight: 700;
  }

  .timeline-company {
    font-size: 0.875rem;
    color: var(--color-accent);
  }

  .timeline-period {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .timeline-desc {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .timeline-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    padding: 0.25rem 0.6rem;
    font-size: 0.7rem;
    font-family: var(--font-mono);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 9999px;
    color: var(--color-text-secondary);
  }
</style>
