---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Hero from "~/components/sections/Hero.astro";
import About from "~/components/sections/About.astro";
import Stack from "~/components/sections/Stack.astro";
import Projects from "~/components/sections/Projects.astro";
import Experience from "~/components/sections/Experience.astro";
import Services from "~/components/sections/Services.astro";
import Certifications from "~/components/sections/Certifications.astro";
import Contact from "~/components/sections/Contact.astro";

const lang = "es" as const;
---

<BaseLayout
  title="Antonio Cortazar — Software Engineer"
  description="Portafolio de Antonio Cortazar Jimenez. Construyo productos web y móviles con Astro, React, Tailwind, AWS y Firebase."
>
  <Hero lang={lang} />
  <About lang={lang} />
  <Stack lang={lang} />
  <Projects lang={lang} />
  <Experience lang={lang} />
  <Services lang={lang} />
  <Certifications lang={lang} />
  <Contact lang={lang} />
</BaseLayout>
