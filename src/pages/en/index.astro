---
import Layout from '../../layouts/Layout.astro';
import { useTranslations } from '../../i18n';

import Navbar from '../../components/Navbar.astro';
import Hero from '../../components/Hero.tsx';
import About from '../../components/About.astro';
import Skills from '../../components/Skills.astro';
import Projects from '../../components/Projects.astro';
import Experience from '../../components/Experience.astro';
import Contact from '../../components/Contact.astro';

const lang = 'en';
const t = useTranslations(lang);
---

<Layout lang={lang}>
  <Navbar lang={lang} t={t} />

  <!-- Hero (React + Framer Motion) -->
  <Hero client:only="react" lang={lang} t={t} />

  <About t={t} />
  <Skills t={t} />
  <Projects t={t} />
  <Experience t={t} />
  <Contact t={t} />

  <!-- Footer -->
  <footer class="border-t border-border py-8 text-center">
    <p class="text-sm text-text-muted">
      © {new Date().getFullYear()} Antonio Cortázar. {t('footer.rights')}.
    </p>
    <p class="text-xs text-text-muted mt-2 font-mono">
      {t('footer.built')}
    </p>
  </footer>
</Layout>
