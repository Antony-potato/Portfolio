---
import BaseLayout from "./BaseLayout.astro";
import Badge from "~/components/ui/Badge.astro";
import Eyebrow from "~/components/ui/Eyebrow.astro";
import Button from "~/components/ui/Button.astro";
import { Icon } from "astro-icon/components";
import { useTranslations, getLocalizedPath, type Lang } from "~/i18n/utils";

interface Props {
  title: string;
  summary: string;
  role: string;
  year: number;
  client?: string | undefined;
  stack: string[];
  category: string;
  cover: string;
  liveUrl?: string | null | undefined;
  repoUrl?: string | null | undefined;
  prevSlug?: string | undefined;
  nextSlug?: string | undefined;
  nextTitle?: string | undefined;
  lang: Lang;
}

const {
  title,
  summary,
  role,
  year,
  client,
  stack,
  category,
  cover,
  liveUrl,
  repoUrl,
  nextSlug,
  nextTitle,
  lang,
} = Astro.props;

const t = useTranslations(lang);
const projectsBase = lang === "es" ? "/proyectos" : "/projects";
const backHref = getLocalizedPath(lang, projectsBase);
const nextHref = nextSlug ? getLocalizedPath(lang, `${projectsBase}/${nextSlug}`) : null;
---

<BaseLayout title={title} description={summary} type="article" image={cover}>
  <article class="pb-32">
    <header class="border-b border-ink-300 dark:border-ink-700">
      <div class="wrapper py-12">
        <a
          href={backHref}
          class="inline-flex items-center gap-2 font-mono text-xs uppercase tracking-wider text-ink-500 dark:text-ink-400 hover:text-accent-500 mb-8"
        >
          <Icon name="lucide:arrow-left" class="size-3" />
          {projectsBase === "/proyectos" ? "Proyectos" : "Projects"}
        </a>

        <div class="grid gap-12 lg:grid-cols-12 lg:gap-8 items-end">
          <div class="lg:col-span-8 flex flex-col gap-6">
            <div class="flex items-center gap-3">
              <Badge variant="accent">{category}</Badge>
              <Eyebrow class="m-0">{year}</Eyebrow>
            </div>
            <h1 class="font-display font-black leading-[0.95] tracking-[-0.03em] text-[clamp(2.5rem,7vw,5.5rem)] text-balance">
              {title}
            </h1>
            <p class="max-w-2xl text-lg md:text-xl text-ink-500 dark:text-ink-400">{summary}</p>
          </div>

          <aside class="lg:col-span-4">
            <dl class="grid grid-cols-2 gap-px bg-ink-300 dark:bg-ink-700 border border-ink-300 dark:border-ink-700">
              <div class="bg-ink-50 dark:bg-ink-950 p-4">
                <dt class="eyebrow">{t("projects.role")}</dt>
                <dd class="mt-1 font-mono text-sm">{role}</dd>
              </div>
              <div class="bg-ink-50 dark:bg-ink-950 p-4">
                <dt class="eyebrow">{t("projects.client")}</dt>
                <dd class="mt-1 font-mono text-sm">{client ?? "—"}</dd>
              </div>
              <div class="bg-ink-50 dark:bg-ink-950 p-4 col-span-2">
                <dt class="eyebrow">{t("projects.stack")}</dt>
                <dd class="mt-1 font-mono text-sm">{stack.join(" · ")}</dd>
              </div>
            </dl>

            <div class="mt-4 flex flex-wrap gap-2">
              {
                liveUrl && (
                  <Button href={liveUrl} variant="primary" size="sm" external>
                    {t("projects.live")} <Icon name="lucide:arrow-up-right" class="size-3" />
                  </Button>
                )
              }
              {
                repoUrl && (
                  <Button href={repoUrl} variant="secondary" size="sm" external>
                    {t("projects.repo")} <Icon name="simple-icons:github" class="size-3" />
                  </Button>
                )
              }
            </div>
          </aside>
        </div>
      </div>
    </header>

    <div class="wrapper py-12">
      <div class="aspect-[16/9] overflow-hidden border border-ink-300 dark:border-ink-700 bg-ink-100 dark:bg-ink-900">
        <img
          src={cover}
          alt={title}
          loading="eager"
          decoding="async"
          class="size-full object-cover"
        />
      </div>
    </div>

    <div class="wrapper">
      <div class="prose prose-lg dark:prose-invert max-w-3xl mx-auto py-12">
        <slot />
      </div>
    </div>

    {
      nextHref && nextTitle && (
        <nav class="wrapper py-16 border-t border-ink-300 dark:border-ink-700" aria-label="Project navigation">
          <a
            href={nextHref}
            class="group flex flex-col gap-2 items-end text-right hover:text-accent-500 transition-colors"
          >
            <Eyebrow>{t("projects.next")} →</Eyebrow>
            <span class="font-display text-3xl md:text-5xl font-bold">{nextTitle}</span>
          </a>
        </nav>
      )
    }
  </article>
</BaseLayout>

<style is:global>
  .prose {
    color: var(--fg);
  }
  .prose h2 {
    font-family: var(--font-sans);
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    font-size: 2rem;
  }
  .prose h3 {
    font-family: var(--font-sans);
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    font-size: 1.5rem;
  }
  .prose p,
  .prose ul,
  .prose ol {
    margin-bottom: 1.25rem;
    line-height: 1.7;
  }
  .prose ul {
    list-style: none;
    padding-left: 0;
  }
  .prose ul li {
    position: relative;
    padding-left: 1.5rem;
  }
  .prose ul li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--color-accent-500);
    font-family: var(--font-mono);
  }
  .prose strong {
    color: var(--color-accent-600);
  }
  :root.theme-dark .prose strong {
    color: var(--color-accent-400);
  }
  .prose code {
    font-family: var(--font-mono);
    background: color-mix(in srgb, var(--fg) 6%, transparent);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.875em;
  }
  .prose a {
    color: var(--color-accent-600);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }
  :root.theme-dark .prose a {
    color: var(--color-accent-400);
  }
</style>
